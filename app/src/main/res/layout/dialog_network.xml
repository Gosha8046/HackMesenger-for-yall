<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/panel">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- MY IP -->
        <TextView
            android:id="@+id/myIpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="МОЙ IP: ..."
            android:textColor="@color/cyan"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:paddingBottom="16dp"/>

        <!-- SERVER -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// СЕРВЕР //" android:textColor="@color/dg"
            android:textSize="10sp" android:fontFamily="monospace"
            android:letterSpacing="0.1" android:paddingBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingBottom="4dp">
            <EditText android:id="@+id/editPort" android:layout_width="80dp" android:layout_height="40dp"
                android:background="@drawable/input_bg" android:textColor="@color/green"
                android:text="55555" android:textSize="11sp" android:fontFamily="monospace"
                android:paddingStart="8dp" android:inputType="number" android:hint="порт"/>
            <EditText android:id="@+id/editKey" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:layout_marginStart="8dp"
                android:background="@drawable/input_bg" android:textColor="@color/green"
                android:textColorHint="@color/ddg" android:hint="пароль (необязательно)"
                android:textSize="11sp" android:fontFamily="monospace"
                android:paddingStart="8dp" android:inputType="textPassword"/>
        </LinearLayout>

        <Button android:id="@+id/btnStartServer" android:layout_width="match_parent"
            android:layout_height="44dp" android:text="▶ ЗАПУСТИТЬ СЕРВЕР"
            android:textColor="@color/green" android:textSize="11sp" android:fontFamily="monospace"
            android:background="@drawable/btn_send_bg" android:layout_marginBottom="16dp"/>

        <!-- CLIENT -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// ПОДКЛЮЧИТЬСЯ //" android:textColor="@color/dg"
            android:textSize="10sp" android:fontFamily="monospace"
            android:letterSpacing="0.1" android:paddingBottom="8dp"/>

        <EditText android:id="@+id/editHost" android:layout_width="match_parent" android:layout_height="40dp"
            android:background="@drawable/input_bg" android:textColor="@color/green"
            android:textColorHint="@color/ddg" android:hint="IP адрес сервера"
            android:textSize="12sp" android:fontFamily="monospace"
            android:paddingStart="10dp" android:inputType="textUri"
            android:layout_marginBottom="4dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingBottom="4dp">
            <EditText android:id="@+id/editPort2" android:layout_width="80dp" android:layout_height="40dp"
                android:background="@drawable/input_bg" android:textColor="@color/green"
                android:text="55555" android:textSize="11sp" android:fontFamily="monospace"
                android:paddingStart="8dp" android:inputType="number" android:hint="порт"/>
            <EditText android:id="@+id/editKey2" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:layout_marginStart="8dp"
                android:background="@drawable/input_bg" android:textColor="@color/green"
                android:textColorHint="@color/ddg" android:hint="пароль"
                android:textSize="11sp" android:fontFamily="monospace"
                android:paddingStart="8dp" android:inputType="textPassword"/>
        </LinearLayout>

        <Button android:id="@+id/btnConnect" android:layout_width="match_parent"
            android:layout_height="44dp" android:text="⇒ ПОДКЛЮЧИТЬСЯ"
            android:textColor="@color/green" android:textSize="11sp" android:fontFamily="monospace"
            android:background="@drawable/btn_send_bg" android:layout_marginBottom="12dp"/>

        <!-- LOG -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="// ЛОГ //" android:textColor="@color/ddg"
            android:textSize="9sp" android:fontFamily="monospace" android:paddingBottom="4dp"/>

        <TextView android:id="@+id/netLog" android:layout_width="match_parent"
            android:layout_height="80dp" android:background="@color/bg"
            android:textColor="@color/dg" android:textSize="10sp" android:fontFamily="monospace"
            android:padding="8dp" android:text="// ожидание... //"/>

    </LinearLayout>
</ScrollView>
