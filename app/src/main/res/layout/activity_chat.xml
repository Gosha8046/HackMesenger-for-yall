<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/panel"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="◁"
            android:textSize="18sp"
            android:textColor="@color/dg"
            android:fontFamily="monospace"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:id="@+id/chatTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="// ЧАТ //"
            android:textColor="@color/green"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

    <!-- MESSAGES -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="@color/bg">

        <LinearLayout
            android:id="@+id/msgContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>
    </ScrollView>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

    <!-- INPUT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/panel"
        android:padding="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnAttach"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="📎"
            android:textSize="18sp"
            android:background="@drawable/btn_icon_bg"
            android:padding="0dp"/>

        <EditText
            android:id="@+id/inputEdit"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/input_bg"
            android:textColor="@color/green"
            android:textColorHint="@color/ddg"
            android:hint="// сообщение..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine"
            android:maxLines="4"/>

        <Button
            android:id="@+id/btnSend"
            android:layout_width="52dp"
            android:layout_height="44dp"
            android:text="▶"
            android:textSize="16sp"
            android:textColor="@color/green"
            android:background="@drawable/btn_send_bg"
            android:padding="0dp"/>

    </LinearLayout>

</LinearLayout>
